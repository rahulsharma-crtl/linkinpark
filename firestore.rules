rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow collection wide read for compatibility matching
    match /users {
      allow read: if request.auth != null;
    }

    // Teams and Project Rooms
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid in resource.data.members || request.auth.uid == resource.data.createdBy);
      
      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }
    }
  }
}
